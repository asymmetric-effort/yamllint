{
  "name": "@asymmetric-effort/yamllint",
  "version": "0.0.6",
  "description": "A zero-dependency TypeScript YAML parser, linter, and validator with detailed error reporting",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "yamllint": "build/bin.js"
  },
  "files": [
    "build/**/*.js",
    "build/**/*.d.ts"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "node --import tsx/esm --test tests/unit/*.test.ts tests/integration/*.test.ts tests/e2e/*.test.ts",
    "test:unit": "node --import tsx/esm --test tests/unit/*.test.ts",
    "test:integration": "node --import tsx/esm --test tests/integration/*.test.ts",
    "test:e2e": "node --import tsx/esm --test tests/e2e/*.test.ts",
    "build": "tsc",
    "clean": "rm -rf build bin coverage"
  },
  "keywords": [
    "yaml",
    "yml",
    "linter",
    "lint",
    "validator",
    "checker",
    "yamllint",
    "zero-dependencies"
  ],
  "author": "asymmetric-effort",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asymmetric-effort/yamllint.git"
  },
  "homepage": "https://yamllint.asymmetric-effort.com",
  "devDependencies": {
    "@asymmetric-effort/nogginlessdom": "^0.0.5",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.4.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.3.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
