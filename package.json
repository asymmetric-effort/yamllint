{
  "name": "@asymmetric-effort/yamllint",
  "version": "0.0.1",
  "description": "A pure TypeScript YAML linter with configurable rules and detailed error reporting",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "yamllint": "build/bin.js"
  },
  "files": [
    "build/**/*.js",
    "build/**/*.d.ts"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "clean": "rm -rf build bin coverage"
  },
  "keywords": [
    "yaml",
    "yml",
    "linter",
    "lint",
    "validator",
    "checker",
    "yamllint",
    "zero-dependencies"
  ],
  "author": "asymmetric-effort",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asymmetric-effort/yamllint.git"
  },
  "homepage": "https://yamllint.asymmetric-effort.com",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.4.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.3.0",
    "tsx": "^4.22.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  }
}
